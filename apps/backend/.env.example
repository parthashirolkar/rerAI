# -------- LangGraph standalone persistence --------
# Required for threads/runs/checkpoints/store persistence
DATABASE_URI=postgresql://postgres:postgres@localhost:5432/rerai?sslmode=disable

# Auto-create/check persistence tables at startup
LANGGRAPH_SETUP_DB=true

# Required for streaming/pub-sub
REDIS_URI=redis://localhost:6379/0

# Recommended for small free-tier Postgres instances
LANGGRAPH_POSTGRES_POOL_MAX_SIZE=20
N_JOBS_PER_WORKER=10

# Optional but recommended when your graph has sync/blocking code
BG_JOB_ISOLATED_LOOPS=true

# Disable tracing if you do not use LangSmith
LANGSMITH_TRACING=false

# CORS for frontend app
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# -------- Model/provider credentials --------
OPENROUTER_API_KEY=

# -------- MahaRERA optional overrides --------
MAHARERA_PUBLIC_USERNAME=@maharera_public_view
MAHARERA_PUBLIC_PASSWORD=Maharera!@$1
MAHARERA_CRYPTOJS_KEY=sdjhfsdkjgkls74385385

# -------- Chroma Cloud settings --------
CHROMA_API_KEY=
CHROMA_TENANT=c73d822b-82e7-4ba1-bd24-291c352b02f4
CHROMA_DATABASE=RerAI-prod

# Optional local fallback for first-time UDCPR ingestion.
# Relative paths are resolved from the backend working directory.
UDCPR_PDF_DIR=../../data/pdfs
