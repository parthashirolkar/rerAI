{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "edit": "allow",
        "bash": "allow",
        "skill": "allow",
        "webfetch": "allow",
        "doom_loop": "allow",
        "external_directory": "ask"
    },
    "mcp": {
        "exa": {
            "type": "remote",
            "url": "https://mcp.exa.ai/mcp",
            "enabled": true
        },
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": true
        },
        "docs-langchain": {
            "type": "remote",
            "url": "https://docs.langchain.com/mcp"
        },
        "notion": {
            "command": [
                "npx",
                "-y",
                "mcp-remote",
                "https://mcp.notion.com/mcp"
            ],
            "type": "local"
        }
    }
}
